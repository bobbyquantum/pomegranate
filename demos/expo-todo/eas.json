{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local",
    "packageManager": "npm"
  },
  "build": {
    "simulator": {
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_ADAPTER": "loki-memory"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "credentialsSource": "local"
      },
      "env": {
        "EXPO_PUBLIC_ADAPTER": "loki-memory"
      }
    }
  }
}
